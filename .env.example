# ============================================================
# TempMail 环境变量模板
# 复制为 .env 并填写实际值：cp .env.example .env
# ============================================================
#
# ★ 只有两个必填项：SMTP_SERVER_IP 和 SMTP_HOSTNAME
# 其他选项有合理默认值，一般不需要修改。
#

# ---------- SMTP / Mail ----------
# 服务器公网 IP，用于 MX 验证与 SPF 生成（必填）
SMTP_SERVER_IP=1.2.3.4
# 邮件服务器主机名（如 mail.yourdomain.com，推荐填写）
SMTP_HOSTNAME=mail.yourdomain.com

# ---------- 可选配置 ----------
# SQLite 数据库文件路径（容器内路径，一般不需要改）
API_DB_PATH=/data/tempmail.db
# API 速率限制：每令牌每窗口期最大请求数（默认 500）
API_RATE_LIMIT=500
# 速率窗口（秒，默认 60）
API_RATE_WINDOW=60
