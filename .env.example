# ============================================================
# TempMail 环境变量配置模板
# ============================================================
# 使用方法：
#   cp .env.example .env
#   然后按照下方说明修改 .env 中的值
#   最后执行：docker compose up -d
#
# ⚠️  安全提示：.env 文件包含密码，绝不要提交到 Git 仓库！
#     .gitignore 已默认忽略 .env，请勿手动添加。
#
# 端口总览（改端口时必须同步修改多个文件，见各条目说明）：
#   25   — Postfix SMTP 收件端口（公网暴露，接收外部邮件）
#   80   — Nginx 前端+API 反代端口（公网暴露，用户访问）
#   8080 — Go API 内部端口（仅容器内网，不对外暴露）
#   6432 — PgBouncer 数据库代理端口（仅容器内网）
#   5432 — PostgreSQL 原始端口（仅容器内网，不对外暴露）
#   6379 — Redis 端口（仅容器内网，不对外暴露）
# ============================================================

# ============================================================
# 【第一步】PostgreSQL 数据库配置
# ============================================================
# 数据库名称，一般不需要修改
POSTGRES_DB=tempmail

# 数据库用户名
# ⚠️  修改后必须同步修改：
#   - API_DB_DSN（下方，用户名部分）
#   - pgbouncer/pgbouncer.ini 第1行（auth_user=tempmail）
#   - pgbouncer.ini 最后一行（admin_users = tempmail）
POSTGRES_USER=tempmail

# 数据库密码（必须修改！使用强密码）
# ⚠️  修改后必须同步修改：
#   - API_DB_DSN（下方，密码部分，注意 URL 编码 @ → %40）
#   - 如果密码含特殊字符，DB_DSN 中需要对其进行 URL 编码
#     例如：密码 P@ss!  → DB_DSN 中写 P%40ss%21
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# 【第二步】PgBouncer 连接池配置
# （PgBouncer 是 PostgreSQL 前面的连接代理，减少真实 DB 连接数）
# ============================================================
# 连接池模式，transaction 模式性能最好，无需修改
PGBOUNCER_POOL_MODE=transaction

# 最大客户端连接数（API 服务连接到 PgBouncer 的连接数上限）
# 小型部署可改为 1000，无需改其他文件
PGBOUNCER_MAX_CLIENT_CONN=2000

# 每个数据库的默认连接池大小（PgBouncer 到 PostgreSQL 的真实连接数）
# 应小于 PostgreSQL 的 max_connections（docker-compose.yml 中设为 500）
# 小型部署可改为 20
PGBOUNCER_DEFAULT_POOL_SIZE=50

# 最小连接池预热大小，保持至少这么多个常驻连接
PGBOUNCER_MIN_POOL_SIZE=10

# ============================================================
# 【第三步】Redis 配置（用于 API 限速计数器）
# ============================================================
# Redis 密码（必须修改！）
# ⚠️  修改后必须同步修改：
#   - API_REDIS_PASSWORD（下方，必须与此处一致）
REDIS_PASSWORD=change_me_redis_password

# ============================================================
# 【第四步】API 服务配置（Go 后端）
# ============================================================
# API 服务在容器内监听的端口
# ⚠️  修改此值后，必须同步修改以下文件，否则 Nginx 无法转发请求：
#   - docker-compose.yml → api.ports（"8080:8080" 右边的数字）
#   - nginx/default.conf → 所有 proxy_pass http://api:XXXX 处
#   - postfix/entrypoint.sh → sync-domains.sh 中 http://api:8080 处
API_PORT=8080

# API 连接数据库的连接串
# 格式：postgres://用户名:密码@主机:端口/数据库名?参数
# ⚠️  注意事项：
#   - 主机名固定为 pgbouncer（Docker Compose 服务名，不要改）
#   - 端口 6432 是 PgBouncer 端口（修改 PgBouncer 端口时需同步修改此处）
#   - 密码中的特殊字符必须 URL 编码（@ → %40，! → %21，# → %23）
#   - POSTGRES_USER 和 POSTGRES_PASSWORD 改了，此处也要改
API_DB_DSN=postgres://tempmail:change_me_strong_password@pgbouncer:6432/tempmail?sslmode=disable

# Redis 地址
# ⚠️  主机名固定为 redis（Docker Compose 服务名），端口 6379 是 Redis 默认端口
#   如果修改了 Redis 容器名或端口，此处需同步修改
API_REDIS_ADDR=redis:6379

# Redis 密码，必须与 REDIS_PASSWORD 保持一致
API_REDIS_PASSWORD=change_me_redis_password

# 速率限制：每个 API Key 在 API_RATE_WINDOW 秒内最多请求次数
# 例如：500次/60秒 = 约 8.3 次/秒
# 小型部署可降低到 100，高并发可提高到 2000
API_RATE_LIMIT=500

# 速率限制时间窗口（秒）
API_RATE_WINDOW=60

# ============================================================
# 【第五步】管理员配置
# ============================================================
# 初始管理员用户名（仅作记录，实际账号在数据库 init.sql 中创建）
# 管理员 API Key 启动后写入 ./data/admin.key 文件，执行以下命令查看：
#   cat ./data/admin.key
ADMIN_USERNAME=admin

# ============================================================
# 【第六步】SMTP / 邮件服务器配置（最重要！）
# ============================================================
# 服务器公网 IP 地址（必须填写！）
# 用途：
#   1. MX 验证时与 DNS 解析结果比对（验证 MX 记录是否指向本服务器）
#   2. 在"添加域名"界面自动生成 SPF 记录提示（v=spf1 ip4:此IP ~all）
# ⚠️  填写你的服务器公网 IP，不要填内网 IP 或 127.0.0.1
SMTP_SERVER_IP=1.2.3.4

# 邮件服务器主机名（强烈建议填写！）
# 用途：
#   1. 作为 MX 记录的目标值（用户添加域名时，MX 记录指向此主机名）
#   2. 设置后用户只需配置一条 MX 记录，无需额外的 A 记录
#   3. 同时用作 Postfix 的 myhostname（影响 SMTP 握手时的 banner）
# ⚠️  修改此值后，必须同步修改：
#   - postfix/main.cf → myhostname 和 mydomain 行
#   - （entrypoint.sh 会自动用此环境变量覆盖 main.cf，所以 main.cf 的值
#     其实只是 Docker 构建时的默认值，运行时以此处为准）
# 例如：你的服务器域名是 example.com，则填 mail.example.com
#       然后在 DNS 添加 A 记录：mail.example.com → SMTP_SERVER_IP
SMTP_HOSTNAME=mail.yourdomain.com
